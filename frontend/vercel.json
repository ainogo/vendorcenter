{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/og-image.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://vendorcenter-production.up.railway.app/api/$1" },
    { "source": "/company/(.*)", "destination": "/company.html" },
    { "source": "/vendor/(.*)", "destination": "/vendor.html" },
    { "source": "/((?!assets|company\\.html|vendor\\.html).*)", "destination": "/index.html" }
  ]
}
